" Height
set lines=50
" Width
set columns=150
" Background
set background=dark

" Font
"   - https://github.com/yuru7/HackGen
"set guifont=HackGen:h14
"set guifont=UDEV_Gothic_Regular:h15
"set guifont=UDEV_Gothic_NF_Regular:h12
"set guifont=Explex:h12
"set guifont=Explex_Console_NF:h12
set guifont=Explex_Console_NF:h11
"set guifont=Moralerspace_Radon_HWJPDOC:h12
"set guifont=Moralerspace_Radon_HWNF:h12
"set guifont=Ricty_Diminished:h12
"set guifont=JetBrains_Mono:h13

" No menu and toolbar
"   - https://stackoverflow.com/questions/13525518/how-to-hide-the-menu-tool-bar-of-gvim/13525565
set guioptions-=m
set guioptions-=T

" Color scheme
"   - https://alvinalexander.com/blog/post/linux-unix/how-set-vim-gvim-default-color-scheme/ 
"colorscheme desert
"colorscheme dracula
"colorscheme catppuccin_latte
"colorscheme catppuccin_frappe
"colorscheme catppuccin_macchiato
"colorscheme catppuccin_mocha
"colorscheme tokyonight
"colorscheme tender
colorscheme iceberg

" tokyonight-vim
"
" https://github.com/ghifarit53/tokyonight-vim
"set termguicolors
"
"let g:tokyonight_style = 'storm' " available: night, storm
"let g:tokyonight_enable_italic = 1
